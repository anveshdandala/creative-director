// Prisma schema for AI Content Director backend
// Provider: Prisma Postgres (provisioned via Prisma Compute)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Internal user record. Created on first sign-in via POST /api/auth/sync.
/// clerkId is stored only here — nowhere else in the codebase uses it.
model User {
  id        String       @id @default(cuid())   // Our own internal user id
  clerkId   String       @unique                // Used only during sync; never exposed further
  email     String       @unique
  name      String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  generations Generation[]
}

/// Tracks every AI generation tied to an internal User.
model Generation {
  id        String   @id @default(cuid())
  userId    String                              // Internal User.id (NOT Clerk id)
  type      String                              // "guide" | "validate"
  input     String                              // JSON-encoded request payload
  output    String                              // JSON-encoded AI response
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}
